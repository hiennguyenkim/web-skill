# LLM Provider selection (gemini or deepseek)
LLM_PROVIDER=gemini

# API keys for the Gemini LLM engine
GEMINI_API_KEY=your_gemini_api_key_here
# LLM model identifier (optional, defaults to gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash

# API keys and config for DeepSeek LLM engine (optional, if using deepseek provider)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_BASE=https://api.deepseek.com

# SQLite Database path config (optional)
DATABASE_URL=sqlite:///d:/ai-web-skill/web_creator.db

# Redis Broker URL for Celery background tasks (required for queueing)
REDIS_URL=redis://localhost:6379/0
